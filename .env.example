# ─────────────────────────────────────────────────────────────────────────────
# Kompagnon — Variables d'environnement
# Copier ce fichier en .env.local et remplir toutes les valeurs requises.
# Ne jamais committer .env.local dans git.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Créer un projet sur https://supabase.com → Settings > API

# URL publique du projet Supabase (ex: https://xxxx.supabase.co)
# REQUIS
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"

# Clé anonyme publique (anon key) — utilisée côté client + SSR
# REQUIS
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Clé service role (service_role key) — contourne le RLS, utilisée côté serveur uniquement
# REQUIS — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY="eyJ..."


# ── Application ───────────────────────────────────────────────────────────────

# URL publique de l'application (sans slash final)
# Utilisée pour les liens de signature (devis), les callbacks OAuth, les emails
# En local : http://localhost:3000
# En production : https://mondomaine.fr
# REQUIS
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ── Resend (emails transactionnels) ───────────────────────────────────────────
# Créer un compte sur https://resend.com → API Keys

# Clé API Resend
# REQUIS pour l'envoi d'emails (devis, factures, invitations équipe)
RESEND_API_KEY="re_..."

# Adresse email expéditeur pour les emails d'authentification (OTP, reset password)
# Doit être un domaine vérifié dans Resend
# REQUIS si les emails d'auth sont activés
RESEND_FROM_ADDRESS="noreply@mondomaine.fr"

# Nom affiché comme expéditeur pour les emails d'authentification
# OPTIONNEL — défaut : "Kompagnon"
RESEND_FROM_NAME="Mon Entreprise"

# Note : l'adresse expéditeur pour les emails métier (devis, factures) est
# configurée par client dans Settings > Email (stockée en DB dans organizations).


# ── IA — Stack complète ───────────────────────────────────────────────────────
#
# Stack choisie (optimisée coût/performance BTP) :
#
#   Transcription vocale  → Voxtral Mini Transcribe V2 (Mistral direct) ~$0.003/min
#   Génération devis      → Gemini 2.5 Flash (OpenRouter)               ~$0.002/devis
#   Cas complexes PDF     → Claude Sonnet 4.6 (OpenRouter, fallback)    ~$0.02/req
#   Embeddings / RAG      → text-embedding-3-small OpenAI (OpenRouter)  ~$0.02/M tokens
#
# ─────────────────────────────────────────────────────────────────────────────

# Mode IA : "demo" = modèles gratuits OpenRouter, "production" = modèles payants
# "demo"       → Llama 3.3 70B (texte) + Mistral Small 3.1 (vision) — gratuit, 200 req/jour
# "production" → Gemini 2.5 Flash Lite (texte) + fallback Claude Sonnet 4.6
AI_MODE="demo"

# Clé API Mistral (transcription vocale Voxtral Mini Transcribe V2)
# Obtenir : https://console.mistral.ai → API Keys
# REQUIS pour le bouton micro dans l'éditeur de devis
MISTRAL_API_KEY="..."

# Clé API OpenRouter (Gemini 2.5 Flash + Claude Sonnet 4.6 fallback + embeddings)
# Obtenir : https://openrouter.ai/keys
# REQUIS pour l'analyse IA, la génération de devis, les embeddings mémoire
#
# Modèles utilisés via OpenRouter :
#   Génération devis          → google/gemini-2.5-flash-lite (~$0.001/devis, thinking activable)
#   Fallback cas complexes    → anthropic/claude-sonnet-4-6 ou google/gemini-2.5-flash (thinking full)
#   Embeddings RAG            → qwen/qwen3-embedding-8b ($0.01/M tokens, MTEB n°1 multilingue)
OPENROUTER_API_KEY="sk-or-..."


# ── Tâches planifiées (CRON) ──────────────────────────────────────────────────
# Les tâches CRON (relances automatiques, etc.) sont déclenchées par le Cloudflare Worker
# `workers/auto-reminder` via un appel HTTP sécurisé par ce secret.
# Générer une valeur aléatoire forte (ex: openssl rand -hex 32)
# REQUIS si les relances automatiques sont activées (Settings > Rappels)
CRON_SECRET="un-secret-tres-long-et-aleatoire"

# Salt optionnel pour hasher les identifiants du rate limit DB.
# Si absent, l'app utilise CRON_SECRET puis SUPABASE_SERVICE_ROLE_KEY en fallback.
RATE_LIMIT_SECRET=""

# Limites par défaut, ajustables par client.
AI_RATE_LIMIT_PER_HOUR="120"
PUBLIC_FORM_RATE_LIMIT_PER_HOUR="5"


# ── Cockpit opérateur Orsayn ──────────────────────────────────────────────────
# Ces variables permettent à l'instance cliente de remonter ses coûts IA au cockpit.
# Toutes optionnelles : sans elles, les appels IA fonctionnent mais ne sont pas synchronisés.

# URL d'ingestion du cockpit (ex: https://cockpit.orsayn.fr/api/operator/ingest)
OPERATOR_INGEST_URL=""

# Secret HMAC partagé entre toutes les instances clientes et le cockpit
# Générer : openssl rand -hex 32
OPERATOR_INGEST_SECRET=""

# Identifiant de cette instance dans le cockpit (ex: maconnerie-durand, weber-demo)
# Défaut automatique : host extrait de NEXT_PUBLIC_APP_URL
OPERATOR_SOURCE_INSTANCE=""

# ── Cockpit Orsayn (uniquement sur le déploiement opérateur) ──────────────────
# À ne pas renseigner sur les instances clientes.

# Active la page /orsayn et l'endpoint d'ingestion privé.
OPERATOR_MODE="false"

# Liste d'emails autorisés à voir le cockpit (séparés par des virgules).
OPERATOR_ALLOWED_EMAILS=""

# Projet Supabase dédié au cockpit opérateur.
OPERATOR_SUPABASE_URL=""
OPERATOR_SUPABASE_SERVICE_ROLE_KEY=""

# Taux fixe V1 utilisé pour convertir les coûts IA USD en EUR dans le cockpit.
# Exemple : 0.92 signifie 1 USD = 0.92 EUR.
OPERATOR_USD_TO_EUR_RATE="0.92"


# ── Mentions légales publiques ────────────────────────────────────────────────
# Utilisées par /privacy, /terms, /legal et réutilisables sur la future landing.

# Nom affiché de l'éditeur / marque
NEXT_PUBLIC_LEGAL_PUBLISHER_NAME="Orsayn"

# Dénomination légale de l'entité éditrice
NEXT_PUBLIC_LEGAL_COMPANY_NAME="Samuel Mbeboura, entrepreneur individuel exerçant sous le nom commercial Orsayn"

# Adresse publique de l'éditeur
NEXT_PUBLIC_LEGAL_ADDRESS="1 rue des héraults"

# Téléphone public
NEXT_PUBLIC_LEGAL_PHONE="0651664068"

# Formulation libre d'immatriculation (EI, SIREN/SIRET, RCS si applicable)
NEXT_PUBLIC_LEGAL_REGISTRATION="Entrepreneur individuel immatriculé sous le SIRET 98920815200011"

# Numéro de TVA intracommunautaire si applicable
NEXT_PUBLIC_LEGAL_VAT_NUMBER=""

# Directeur de la publication
NEXT_PUBLIC_LEGAL_PUBLICATION_DIRECTOR="Samuel Mbeboura"

# Hébergeur public
NEXT_PUBLIC_LEGAL_HOSTING_PROVIDER="Cloudflare, Inc."
NEXT_PUBLIC_LEGAL_HOSTING_WEBSITE="https://www.cloudflare.com"

# Contacts publics
NEXT_PUBLIC_SUPPORT_EMAIL="contact@orsayn.fr"
NEXT_PUBLIC_PRIVACY_EMAIL="contact@orsayn.fr"
NEXT_PUBLIC_LEGAL_EMAIL="contact@orsayn.fr"
